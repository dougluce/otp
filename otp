TEST_RECIPIENT = "ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAAID6yvOHAVwomZVmof0oh/CrvsPUgZu2EelWAel4b3NY9 otp-test"

def test(args):
  """Builds the keyfile fixture by encrypting this docstring's contents with
  a throwaway key pair, so there's no opaque binary blob to maintain.
  Decrypted file contents:
  alpha DXGB265VIPTKJJAY
  beta HWLQWPRTFVCZRKNZ
  second-beta ACFBSDJG5UIPXEM4
  """
  global KEYFILE, IDENTITY
  import doctest, tempfile, os, inspect
  from pyrage import encrypt, ssh

  # Pull the entry lines straight out of this function's docstring.
  doc = inspect.getdoc(test)
  plaintext = doc.split("Decrypted file contents:\n", 1)[1].encode()

  recipient = ssh.Recipient.from_str(TEST_RECIPIENT)
  ciphertext = encrypt(plaintext, [recipient])

  id_file = tempfile.NamedTemporaryFile(mode='w', delete=False)
  data_file = tempfile.NamedTemporaryFile(delete=False)
  try:
    id_file.write(TEST_IDENTITY)
    id_file.close()
    data_file.write(ciphertext)
    data_file.close()
    KEYFILE = data_file.name
    IDENTITY = id_file.name
    result = doctest.testmod(verbose = args.verbose, exclude_empty = True)
    if result.failed == 0:
      print(f'{result.attempted} successful tests')
  finally:
    os.unlink(id_file.name)
    os.unlink(data_file.name)

def main():
  parser = argparse.ArgumentParser()
  parser.add_argument('term',  nargs='?', default='', help='Search term for finding the relevant key(s)')
  group = parser.add_mutually_exclusive_group()
  group.add_argument('-q', '--qr_code', help='produce a QR code for the found key(s)', action='store_true')
  group.add_argument('-x', '--xml', help='Output XML for option enumeration by Alfred', action='store_true')
  parser.add_argument('-e', '--exact', help="Match must be exact, don't search substrings.", action='store_true')
  parser.add_argument('-t', '--test', help="Run doctests", action='store_true')
  parser.add_argument('-v', '--verbose', help="Run doctests verbosely", action='store_true')
  args = parser.parse_args()
  if args.test:
    test(args)
  else:
    sys.stdout.write(make_output(args.term, args.xml, args.exact, args.qr_code))

if __name__ == "__main__":
  main()
